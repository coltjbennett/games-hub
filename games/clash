      const enemiesNearby = unitsList.some(u=>u.side!==this.side && u.alive && !(u.hut||u.pump||u.turret||u.furnace) && Math.hypot(u.x - this.x, u.y - this.y) <= (this.furnaceDetectionRadius * ART_SCALE * globalScale));
      if(enemiesNearby && this.furnaceSpawnTimer <= 0){
