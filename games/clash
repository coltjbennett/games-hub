<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Colton’s Knockoff Clash Royale</title>
<style>
:root{
  --bg:#0a0a0a;
  --panel:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.01));
  --muted:#9aa3ac;
  --accent:#2f9bff;
  --elixir:#ffd54f;
  --glass-border: rgba(255,255,255,0.04);
  --btn-bg: linear-gradient(180deg,#0f1114,#0b0d10);
  --ui-glow: rgba(47,155,255,0.06);
}
/* base */
html,body{height:100%;margin:0;background:var(--bg);color:#eaf0f6;font-family:Inter,system-ui,Segoe UI,Roboto,"Helvetica Neue",Arial;-webkit-font-smoothing:antialiased}
#container{position:fixed;inset:0}
canvas{display:block;position:absolute;background:linear-gradient(180deg,#0e1012,#0b0c0d)}
/* UI: nicer textures - subtle noise + glass */
#topBar{position:absolute;top:8px;left:8px;right:8px;display:flex;gap:10px;align-items:center;justify-content:center;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.03));padding:10px;border-radius:12px;box-shadow:0 12px 40px rgba(0,0,0,0.6);z-index:40;flex-wrap:wrap;backdrop-filter: blur(6px);border:1px solid var(--glass-border);background-image: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.02)), repeating-linear-gradient(45deg, rgba(255,255,255,0.01) 0px, rgba(255,255,255,0.01) 1px, transparent 1px, transparent 6px); }
#ui{position:absolute;bottom:8px;left:8px;right:8px;display:flex;gap:10px;align-items:center;justify-content:space-between;background:linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.03));padding:10px;border-radius:12px;box-shadow:0 12px 40px rgba(0,0,0,0.6);z-index:40;flex-wrap:nowrap;backdrop-filter: blur(6px);border:1px solid var(--glass-border);background-image: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0.02)), repeating-linear-gradient(90deg, rgba(255,255,255,0.01) 0px, rgba(255,255,255,0.01) 1px, transparent 1px, transparent 6px); }
#cardButtons{display:flex;flex-direction:row;gap:8px;align-items:center;overflow-x:auto;-webkit-overflow-scrolling:touch;padding:4px 2px;min-height:56px;flex:1 1 auto;scrollbar-width:thin}
#cardButtons::-webkit-scrollbar{height:8px}
#cardButtons::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.06);border-radius:8px}
#spellButtons{display:flex;flex-direction:column;gap:8px;align-items:center;padding:4px 2px;min-height:56px;flex:0 0 auto}

/* buttons largely unchanged shape; pause/reset/delete are compact */
.btn{background:var(--btn-bg);color:#eaf0f6;padding:10px 12px;border-radius:12px;cursor:pointer;font-size:14px;display:inline-flex;align-items:center;gap:8px;width:140px;box-sizing:border-box;justify-content:space-between;border:2px solid rgba(255,255,255,0.03);transition: transform .08s ease, opacity .12s ease, box-shadow .12s ease;box-shadow:0 6px 18px rgba(0,0,0,0.5);flex:0 0 auto;touch-action: manipulation;position:relative;overflow:visible}
.btn:active{transform: translateY(0)}
.btn.disabled{opacity:.45;cursor:not-allowed;transform:none;filter:grayscale(.6) brightness(.9)}
.cardLabel{display:flex;flex-direction:column;align-items:center;gap:4px;overflow:visible;white-space:normal;text-overflow:unset;justify-content:center}
.cardIcon{display:inline-block;width:22px;height:22px;border-radius:50%;vertical-align:middle;margin:0;flex-shrink:0;box-shadow:0 0 0 3px rgba(255,255,255,0.02) inset}
.cardName{font-weight:600;font-size:13px;color:#eaf0f6;overflow-wrap:anywhere;word-break:break-word;white-space:normal;text-overflow:unset;text-align:center;line-height:1.05;display:block;padding:0 2px;max-height:3.0em}
.cost{font-weight:700;color:var(--elixir);font-size:13px;margin-left:8px;white-space:nowrap}
.selected{box-shadow:0 14px 40px rgba(47,155,255,0.14);border:2px solid rgba(47,155,255,0.28) !important}
.status{font-size:13px;color:var(--muted);margin:0 8px}
.elixirBar{width:160px;height:14px;background:linear-gradient(90deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));border-radius:8px;overflow:hidden;border:1px solid rgba(255,255,255,0.03);box-shadow: inset 0 2px 6px rgba(0,0,0,0.6)}
.elixirFill{height:100%;background:linear-gradient(90deg,#5346E8,#BC5EEB);width:0%}
#topLeft{position:absolute;left:12px;top:12px;color:var(--muted);font-size:13px;pointer-events:none}
#topRight{position:absolute;right:12px;top:12px;color:var(--muted);font-size:16px;font-weight:600;pointer-events:none}
.small{font-size:12px;color:var(--muted)}
footer{position:absolute;left:12px;bottom:70px;color:rgba(200,200,200,0.04);font-size:11px;pointer-events:none}
button.btn{-webkit-tap-highlight-color: transparent}

/* cooldown overlay */
.btn .coolOverlay{position:absolute;left:0;top:0;right:0;bottom:0;border-radius:12px;pointer-events:none;display:flex;align-items:flex-end;justify-content:center;overflow:hidden;opacity:0;transition:opacity .12s ease}
.btn .coolOverlay .coolFill{width:100%;height:0%;background:linear-gradient(180deg,rgba(0,0,0,0.45),rgba(20,20,20,0.65));mix-blend-mode:multiply;transform-origin:bottom;transition:height .08s linear}
.btn .coolOverlay .coolText{position:absolute;left:0;right:0;bottom:6px;text-align:center;font-weight:700;font-size:12px;color:rgba(255,255,255,0.9);text-shadow:0 1px 0 rgba(0,0,0,0.6)}

/* Pause/Reset/Delete stacked and smaller */
#controlsColumn{display:flex;flex-direction:column;gap:6px;align-items:center}
#pauseBtn, #resetBtn, #deleteBtn { width:84px !important; padding:6px 8px !important; font-size:12px !important; height:auto !important; }

/* Spell buttons compact (removed icon, less vertical padding) */
.btn.spellCompact{ padding:6px 10px; height:auto; display:flex; align-items:center; justify-content:center; width:130px; }
.btn.spellCompact .cardLabel{flex-direction:row; gap:6px;}
.btn.spellCompact .cardName{font-size:13px}

/* delete mode highlight */
.btn.deleteActive{ box-shadow:0 18px 60px rgba(255,80,80,0.16); border:2px solid rgba(255,100,100,0.28) !important; }

/* small visual helper for deletion cursor */
.canvas-delete-cursor { cursor:crosshair !important; }
</style>
</head>
<body>
<div id="container">
  <div id="topBar" aria-hidden="false">
    <div style="display:flex;align-items:center;gap:8px;">
      <div class="elixirBar" title="Player Elixir"><div id="elixirFillP" class="elixirFill"></div></div>
      <div class="status" id="elixirTextP">P: 0.0</div>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
      <div class="elixirBar" title="Enemy Elixir"><div id="elixirFillE" class="elixirFill"></div></div>
      <div class="status" id="elixirTextE">E: 0.0</div>
    </div>
    <div style="margin-left:10px;color:var(--muted);font-size:13px">Touch to deploy. Space still pauses (kept for convenience).</div>
  </div>

  <canvas id="game"></canvas>

  <div id="ui" aria-hidden="false">
    <div id="cardButtons" role="group" aria-label="Unit Buttons"></div>
    <div id="spellButtons" role="group" aria-label="Spell Buttons"></div>
    <div id="controlsColumn">
      <button id="pauseBtn" class="btn">Pause</button>
      <button id="resetBtn" class="btn">Reset</button>
      <button id="deleteBtn" class="btn">Delete</button>
    </div>
  </div>

  <div id="topLeft" class="small">Colton’s Knockoff Clash Royale</div>
  <div id="topRight" class="small"></div>
  <footer>Buildings are rectangles; units are colored circles with blue/red outlines and tiny labels.</footer>
</div>

<script>
/* ---------- CONFIG & DATA ---------- */
const ART_SCALE = 1.4; // your +40% art scale (applied before playfield scaling)
const BASE_W = 1400, BASE_H = 900;
let globalScale = 1, prevScale = 1;
// near top where CONFIG is defined:
const ENEMY_SPAWN_BASE = 2500; // ms
const ENEMY_SPAWN_JITTER = 2500; // ms

const canvas = document.getElementById('game'), ctx = canvas.getContext('2d',{alpha:false});
const topBar = document.getElementById('topBar'), bottomUI = document.getElementById('ui'), cardButtons=document.getElementById('cardButtons'), spellButtons=document.getElementById('spellButtons');

let W=0, H=0;

const clamp=(v,a,b)=>Math.max(a,Math.min(b,v)), now=()=>performance.now()/1000;

const CONFIG={maxElixir:10,elixirGainPerSec:1,spawnPad:100,towerBaseHP:2750,dtCap:0.05,cardCooldown:1};
const UNIT_HP_MULT=1.5, UNIT_SPD_MULT=0.7, TOWER_SPELL_DMG_MULT=0.01;

/* ---------- ALL UNIT / CARD DEFINITIONS (single DATA object) ---------- */
const DATA = {
  // basic troops
  knight:{hp:320,dmg:130,atkSpd:1.8,spd:70,range:25,cost:3,color:'#9aa3ac',size:14},
  archer:{hp:150,dmg:60,atkSpd:1.6,spd:88,range:130,cost:5,color:'#8fe28f',size:9,projectile:true, spawnCount:2},
  giant:{hp:2500,dmg:350,atkSpd:1,spd:39,range:40,cost:6,color:'#ff9a3c',size:20,giant:true},
  wizard:{hp:220,dmg:120,atkSpd:1.1,spd:58,range:100,cost:6,color:'#c88aff',size:12,splash:true,projectile:true},
  healer:{hp:300,dmg:0,atkSpd:1.2,spd:130,range:120,cost:8,color:'#ff91c8',size:13,heal:true},
  valkyrie:{hp:480,dmg:60,atkSpd:1.1,spd:64,range:30,cost:4,color:'#f3b562',size:15,spin:true},
  goblinHut:{hp:300,hut:true,spawnInterval:0.925,detectionRadius:170,cost:5,color:'#264a2a',size:18,pumpLike:true},
  minipekka:{hp:360,dmg:280,atkSpd:0.6,spd:70,range:25,cost:4,color:'#2b7ce6',size:11,singleTarget:true},
  megaknight:{hp:1600,dmg:0,mdmg:500,atkSpd:1,spd:50,range:150,cost:10,color:'#4b2fb8',size:22,mega:true,giant:true},
  goblins:{cost:4},
  goblin:{hp:70,dmg:80,atkSpd:0.9,spd:120,range:20,cost:0,color:'#2f8f3f',size:6.5},
  elixirPump:{hp:250,pump:true,pumpRate:0.18,cost:8,color:'#213a66',size:16},

  // turret / building-like crossbow
  crossbow: {
    hp: 520,
    dmg: 170,
    atkSpd: 1.0,
    spd: 0,
    range: 180,
    cost: 6,
    color: '#7a4f2b',
    size: 21,
    turret: true,
    projectile: true,
    knockback: 60
  },

  // spirit band card & spirits
  spiritBand: {
    cost: 7,
    band: true,
    spawnCount: 4,
    spirits: ['spirit_fire','spirit_ice','spirit_zap','spirit_boom'],
    size: 10,
    color: '#f0f0f0'
  },
  spirit_fire: { hp: 110, dmg: 15, atkSpd: 2.4, spd: 140, range: 48, cost: 0, color: '#ff6b3a', size: 7, spirit:true, projectile:false },
  spirit_ice:  { hp: 115, dmg: 22, atkSpd: 2.2, spd: 140, range: 70, cost: 0, color: '#9fe0ff', size: 7, spirit:true, projectile:false },
  spirit_zap:  { hp: 105, dmg: 24, atkSpd: 4, spd: 170, range: 80, cost: 0, color: '#f6f8a5', size: 6, spirit:true, projectile:false },
  spirit_boom: { hp: 120, dmg: 150, atkSpd: 1.0, spd: 130, range: 30, cost: 0, color: '#ffb36b', size: 8, spirit:true, projectile:false, splash:true },

  // furnace: mobile troop that spawns furnace_spirit every 7s when enemies are nearby (mobile goblin-hut)
  furnace: {
    hp: 700,
    dmg: 140,
    atkSpd: 0.9,
    spd: 56,
    range: 90,
    cost: 9,
    color: '#c84a1f',
    size: 18,
    furnace: true,
    spawnInterval: 3,
    spawnDetectionRadius: 210,
    // furnace does light melee, but primary role is spawning furnace_spirits
  },
  // bespoke furnace spirit (splash fire like wizard + burn logic like spirit_fire)
  furnace_spirit: {
    hp: 120,
    dmg: 70,
    atkSpd: 1.1,
    spd: 160,
    range: 84,
    cost: 0,
    color: '#ff8f4a',
    size: 8.5,
    spirit:true,
    projectile:false,
    splash:true,            // splash damage like wizard
    burnMultiplier: 2.0     // used to compute burn DPS similarly to spirit_fire
  },

  // GOLEM & GOLEMITES
  golem: {
    hp: 3200,
    dmg: 400,
    atkSpd: 0.6,
    spd: 30,
    range: 98,
    cost: 8,
    color: '#6e6b6b',
    size: 34,
    golem: true
  },
  golemite: {
    hp: 400,
    dmg: 1, // explosion handles damage
    explosionDamage: 600,
    explosionRadius: 150,
    atkSpd: 1,
    spd: 70,
    range: 1,
    cost: 0,
    color: '#9b6b4b',
    size: 7,
    golemitelike: true,
    armDelay: 0 // seconds before "armed" state
  },

  // Replicator
  replicator: {
    hp: 180,
    dmg: 0,
    atkSpd: 1,
    spd: 70,
    range: 300,
    cost: 10,
    color: '#a8d0ff',
    size: 18,
    cloneInterval: 6, //seconds
    cloneMultiplier: { hp: 0.75, dmg: 0.75, spd: 0.75, size: 0.8 },
    replicator: true
  }
};

/* clone multipliers default (easy to tweak globally if you want)
   NOTE: Individual replicators in DATA can override via cloneMultiplier.
*/
const REPLICA_MULT = { hp: 0.75, dmg: 0.75, spd: 0.75, size: 0.75 };

/* ---------- HELPER: spawn multiple units for cards (archer double, spirit band, etc.) ---------- */
function spawnCardUnits(x, y, side, cardType) {
  const def = DATA[cardType] || DATA['goblin'];
  // BAND: explicit list of different unit types (spiritBand)
  if (def.band && Array.isArray(def.spirits)) {
    const offsets = [{x:-12,y:-8},{x:12,y:-8},{x:-12,y:8},{x:12,y:8}];
    for (let i = 0; i < def.spirits.length; i++) {
      const unitName = def.spirits[i];
      const offs = offsets[i % offsets.length];
      const gx = clamp(x + offs.x + (Math.random() - 0.5) * 6 * globalScale, 20 * globalScale, W - 20 * globalScale);
      const gy = clamp(y + offs.y + (Math.random() - 0.5) * 6 * globalScale, 20 * globalScale, H - 20 * globalScale);
      let pos = (typeof findSpawnPosition === 'function') ? findSpawnPosition(gx, gy, side, 8 * globalScale) : {x:gx, y:gy};
      if (pos) units.push(new Unit(pos.x, pos.y, side, unitName));
    }
    return;
  }

  // DEFAULT: spawn multiple copies of the same unit (archer spawnCount:2, goblins handled elsewhere)
  const count = def.spawnCount || 1;
  const spread = 12 * globalScale;
  for (let i = 0; i < count; i++) {
    const ang = (i / Math.max(1, count)) * Math.PI * 2;
    const gx = clamp(x + Math.cos(ang) * spread + (Math.random() - 0.5) * 6 * globalScale, 20 * globalScale, W - 20 * globalScale);
    const gy = clamp(y + Math.sin(ang) * spread + (Math.random() - 0.5) * 6 * globalScale, 20 * globalScale, H - 20 * globalScale);
    let pos = (typeof findSpawnPosition === 'function') ? findSpawnPosition(gx, gy, side, 8 * globalScale) : {x:gx, y:gy};
    if (pos) {
      let unitType = cardType;
      if (cardType === 'goblins') unitType = 'goblin';
      units.push(new Unit(pos.x, pos.y, side, unitType));
    }
  }
}

/* ---------- SPELLS ---------- */
const SPELLS={
  log:{cost:6,color:'#c48b3f',heightFrac:1/3,bodyWidth:25,damage:250,knockback:3000,speed:420,name:'Log'},
  fireball:{cost:4,color:'#ff6b3a',radius:48,damage:550,duration:0.8,name:'Fireball'},
  arrows:{cost:3,color:'#82d2ff',radius:110,damage:200,duration:0.5,name:'Arrows'}
};

/* game state */
let units=[], towers=[], selectedCard='knight', selectedSpell=null, elixirP=5, elixirE=5, running=true, spellsActive=[];
let particles=[]; let explosions=[]; // visual explosion rings
let projectiles = []; // arrow projectiles
let pulses = []; // radiating pulses (wizard/valkyrie/healer)
let swings = []; // swing arcs for melee units
const lastUsedCard = {}; const lastUsedSpell = {};
let deleteMode = false;

/* ---------- UTILS ---------- */
function vecLen(x,y){return Math.hypot(x,y)}
function normalize(x,y){const l=vecLen(x,y);return l>0?[x/l,y/l]:[0,0]}
function limit(x,y,max){const l=vecLen(x,y);if(l>max){const f=max/l;return[x*f,y*f]}return[x,y]}
function isRanged(def){return!!def.splash||((!!def.range)&&def.range>40)||def.heal}

/* Building rect helpers */
function rectFromBuilding(u){
  const w = (u.size||16)*2;
  const h = (u.size||16)*1.6;
  return {left: u.x - w/2, right: u.x + w/2, top: u.y - h/2, bottom: u.y + h/2, w, h};
}
function circleIntersectsRect(cx, cy, radius, r){
  const nearestX = clamp(cx, r.left, r.right);
  const nearestY = clamp(cy, r.top, r.bottom);
  const dx = cx - nearestX, dy = cy - nearestY;
  return (dx*dx + dy*dy) <= (radius*radius);
}
function rectsOverlap(a,b){
  return !(a.left > b.right || a.right < b.left || a.top > b.bottom || a.bottom < b.top);
}
function pointNearRect(px,py,r,margin){
  return px >= (r.left - margin) && px <= (r.right + margin) && py >= (r.top - margin) && py <= (r.bottom + margin);
}

/* ---------- PARTICLES & EFFECTS ---------- */
class Particle {
  constructor(x,y,color, size=6, vx= (Math.random()-0.5)*40, vy=-40 + Math.random()*-20, life=0.9){
    this.x=x; this.y=y; this.vx=vx; this.vy=vy; this.color=color; this.size=size; this.life=life; this.age=0; this.gravity=220*globalScale;
  }
  update(dt){ this.age += dt; this.vy += this.gravity*dt; this.x += this.vx*dt; this.y += this.vy*dt; }
  draw(ctx){ const t = clamp(1 - (this.age/this.life), 0, 1); ctx.globalAlpha = t; ctx.fillStyle = this.color; const s = Math.max(1, this.size * t); ctx.fillRect(this.x - s/2, this.y - s/2, s, s); ctx.globalAlpha = 1; }
  isDone(){ return this.age >= this.life; }
}
function spawnHitParticles(x,y,color,count=6){
  for(let i=0;i<count;i++){
    const s = 3 + Math.random()*6;
    particles.push(new Particle(x + (Math.random()-0.5)*8, y + (Math.random()-0.5)*8, color, s, (Math.random()-0.5)*140, -60 + Math.random()*-40, 0.7 + Math.random()*0.7));
  }
}
function spawnExplosion(x,y,color,power=1){
  explosions.push({x,y,r:0,maxR:60*power*globalScale,life:0.8,age:0,color});
  const count = 18 + Math.floor(18*power);
  for(let i=0;i<count;i++){
    particles.push(new Particle(x + (Math.random()-0.5)*30, y + (Math.random()-0.5)*30, color, 6 + Math.random()*10, (Math.random()-0.5)*500*power, -80 + Math.random()*-200, 0.9 + Math.random()*0.6));
  }
  triggerScreenShake(0.45 * power, 8*power);
}

/* ---------- PULSES & SWINGS ---------- */
/* Pulse alpha set to ~0.20 (80% transparent) per request; pulses radiate outward */
class Pulse {
  constructor(x,y,r,color,duration=0.45,alpha=0.20){
    this.x=x; this.y=y; this.r=r; this.color=color; this.duration=duration; this.alpha=alpha; this.age=0;
  }
  update(dt){ this.age += dt; }
  draw(ctx){
    const t = clamp(this.age / this.duration, 0, 1); // t goes 0 -> 1
    const currentR = this.r * (0.4 + 1.6 * t); // grows from ~40% to 200% of r
    const alpha = this.alpha * (1 - t);
    ctx.save();
    ctx.globalCompositeOperation = 'lighter';
    ctx.globalAlpha = alpha;
    ctx.fillStyle = this.color;
    ctx.beginPath();
    ctx.arc(this.x, this.y, currentR, 0, Math.PI*2);
    ctx.fill();
    ctx.restore();
  }
  isDone(){ return this.age >= this.duration; }
}
class Swing {
  constructor(x,y,r,angle,color,duration=0.35,alpha=0.45){
    this.x=x; this.y=y; this.r=r; this.angle=angle; this.color=color; this.duration=duration; this.age=0; this.alpha=alpha;
  }
  update(dt){ this.age += dt; }
  draw(ctx){
    const p = clamp(1 - (this.age / this.duration), 0, 1);
    ctx.save();
    ctx.globalAlpha = this.alpha * p;
    ctx.strokeStyle = this.color;
    ctx.lineWidth = Math.max(2, Math.min(12, this.r*0.06));
    ctx.beginPath();
    const a1 = this.angle - 0.9 * p, a2 = this.angle + 0.9 * p; // arc width reduces as it fades
    ctx.arc(this.x, this.y, this.r, a1, a2);
    ctx.stroke();
    ctx.restore();
  }
  isDone(){ return this.age >= this.duration; }
}

function spawnPulse(x,y,r,color){
  pulses.push(new Pulse(x,y,Math.max(6, r), color, 0.45, 0.20));
}
function spawnSwing(x,y,r,angle,color){
  swings.push(new Swing(x,y,Math.max(6, r), angle, color, 0.35, 0.45));
}

/* ---------- SCREEN SHAKE ---------- */
let shakeTime=0, shakeIntensity=0;
function triggerScreenShake(duration, intensity){
  shakeTime = Math.max(shakeTime, duration || 0.4);
  shakeIntensity = Math.max(shakeIntensity, intensity || 6);
}

/* ---------- DRAW HELPERS ---------- */
function shadeColor(col, amt){
  try{
    const c = col.replace('#','');
    const num = parseInt(c,16);
    let r = (num>>16)+amt; let g=(num>>8 & 0x00FF)+amt; let b=(num & 0x0000FF)+amt;
    r = clamp(r,0,255); g=clamp(g,0,255); b=clamp(b,0,255);
    return '#'+( (1<<24) + (r<<16) + (g<<8) + b ).toString(16).slice(1);
  }catch(e){ return col; }
}
function drawUnitSprite(ctx,x,y,size,color,side){
  const g = ctx.createRadialGradient(x - size*0.35, y - size*0.45, size*0.1, x, y, size*1.1);
  g.addColorStop(0, '#ffffff'); g.addColorStop(0.05, color); g.addColorStop(1, shadeColor(color, -12));
  ctx.beginPath(); ctx.fillStyle = g; ctx.arc(x,y,size,0,Math.PI*2); ctx.fill();
  ctx.lineWidth = Math.max(1, size*0.08); ctx.strokeStyle = (side==='player') ? 'rgba(80,160,255,0.9)' : 'rgba(255,90,90,0.9)'; ctx.stroke();
  ctx.beginPath(); ctx.fillStyle='rgba(255,255,255,0.08)'; ctx.ellipse(x - size*0.25, y - size*0.25, size*0.35, size*0.2, 0, 0, Math.PI*2); ctx.fill();
}
function drawLabel(ctx,text,x,y,size){ const label=String(text).replace(/([A-Z])/g,' $1').trim(); const fontSize=Math.max(8,Math.min(12,size)); ctx.font=`bold ${fontSize}px sans-serif`; ctx.textAlign='center'; ctx.textBaseline='middle'; ctx.fillStyle='rgba(0,0,0,0.6)'; ctx.fillText(label,x+1,y+1); ctx.fillStyle='rgba(255,255,255,0.95)'; ctx.fillText(label,x,y) }
