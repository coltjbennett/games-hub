pickTarget(unitsList, towersList){
  if (this.type === 'golem') {
    // GOLEM: only structural enemy units (huts, pumps, turrets, pumpLike) that are alive
    const structUnits = unitsList.filter(u => u.side !== this.side && u.alive && (u.hut || u.pump || u.turret || u.pumpLike || u.pumpLike));
    // enemy towers/buildings (ensure they are alive if your code uses an alive flag)
    const structTowers = towersList.filter(t => t.side !== this.side && (t.hp > 0));
    // prefer unit-type buildings first
    if (structUnits.length > 0) {
      let closest = null, bestD = Infinity;
      for (const s of structUnits) {
        const d = Math.hypot(s.x - this.x, s.y - this.y);
        if (d < bestD) { bestD = d; closest = s; }
      }
      return { target: closest, dist: bestD };
    }
    // if no unit-buildings, target towers
    if (structTowers.length > 0) {
      let closest = null, bestD = Infinity;
      for (const t of structTowers) {
        const d = Math.hypot(t.x - this.x, t.y - this.y);
        if (d < bestD) { bestD = d; closest = t; bestD = d; }
      }
      return { target: closest, dist: bestD };
    }
    // nothing to smash
    return { target: null, dist: Infinity };
  }

  if (this.type === 'giant') {
    // only structural enemy units (huts, pumps, turrets, pumpLike) that are alive
    const structUnits = unitsList.filter(u => u.side !== this.side && u.alive && (u.hut || u.pump || u.turret || u.pumpLike));
    // enemy towers/buildings (ensure they are alive if your code uses an alive flag)
    const structTowers = towersList.filter(t => t.side !== this.side && (t.alive ?? true));
    let closest = null, bestD = Infinity;

    for (const s of structUnits) {
      const d = Math.hypot(s.x - this.x, s.y - this.y);
      if (d < bestD) { bestD = d; closest = s; }
    }

    for (const t of structTowers) {
      const d = Math.hypot(t.x - this.x, t.y - this.y); // FIXED: was `t.y < this.y`
      if (d < bestD) { bestD = d; closest = t; }
    }

    return { target: closest, dist: bestD };
  }

  // non-giant behaviour (unchanged logic, but filter towers for alive)
  const enemies = unitsList.filter(u => u.side !== this.side && u.alive);
  const enemyTowers = towersList.filter(t => t.side !== this.side && (t.alive ?? true));

  let closestUnit = null, dU = Infinity;
  for (const e of enemies) {
    const d = Math.hypot(e.x - this.x, e.y - this.y);
    if (d < dU) { dU = d; closestUnit = e; }
  }

  let closestTower = null, dT = Infinity;
  for (const t of enemyTowers) {
    const d = Math.hypot(t.x - this.x, t.y - this.y);
    if (d < dT) { dT = d; closestTower = t; }
  }

  if (closestUnit && closestTower) {
    if (dU < dT * 0.9) return { target: closestUnit, dist: dU };
    return { target: closestTower, dist: dT };
  } else if (closestUnit) return { target: closestUnit, dist: dU };
  else if (closestTower) return { target: closestTower, dist: dT };
  return { target: null, dist: Infinity };
}


