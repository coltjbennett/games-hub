        this.x += this.vx * dt;
        this.y += this.vy * dt;
        const dist = Math.hypot(this._dashOrigin.x - this.x, this._dashOrigin.y - this.y);
        if (dist < 6 || (now() - this._retreatStart) > 1.2) {
          this.x = this._dashOrigin.x;
          this.y = this._dashOrigin.y;
          this.megaState = 'cooldown';
          this.vx = 0;
          this.vy = 0;
        }
      } else if (this.megaState === 'cooldown') {
        this.vx += (this.desiredVx - this.vx) * clamp(dt * 6, 0, 1);
        this.vy += (this.desiredVy - this.vy) * clamp(dt * 6, 0, 1);
        this.x += this.vx * dt;
        this.y += this.vy * dt;
        if (this.megaCooldown <= 0) this.megaState = 'idle';
      }
      this.x = clamp(this.x, 10 * globalScale, W - 10 * globalScale);
      this.y = clamp(this.y, 10 * globalScale, H - 10 * globalScale);
    } else {
      this.vx += (this.desiredVx - this.vx) * clamp(dt * 8, 0, 1);
      this.vy += (this.desiredVy - this.vy) * clamp(dt * 8, 0, 1);
      this.x += this.vx * dt;
      this.y += this.vy * dt;
    }


    if(target){
      const dx=target.x-this.x,dy=target.y-this.y; const distance=Math.hypot(dx,dy);
      if(distance<=this.range+(target.size??0)+2){
        if(this.spin){
          if(this.atkTimer<=0){
            this.atkTimer=this.atkCooldown;
            const rad=64*globalScale;
            for(const u of units.filter(u=>u.side!==this.side&&u.alive)) if(Math.hypot(u.x-this.x,u.y-this.y)<=rad) u.hp-=this.dmg*this.atkCooldown;
            for(const t of towers.filter(t=>t.side!==this.side)) if(Math.hypot(t.x-this.x,t.y-this.y)<=rad) t.hp-=this.dmg*this.atkCooldown;
            // Valkyrie pulse (color = unit color)
            spawnPulse(this.x, this.y, rad, this.color);
          }
        } else if(this.splash && this.type !== 'spirit_boom'){
          // existing generic splash behavior (wizard etc.)
          if(this.atkTimer<=0){
            this.atkTimer=this.atkCooldown;
            const splashRad=Math.max(24*globalScale,this.range*0.5);
            for(const u of units.filter(u=>u.side!==this.side&&u.alive)) if(Math.hypot(u.x-target.x,u.y-target.y)<=splashRad) u.hp-=(this.dmg*this.atkCooldown);
            for(const t of towers.filter(t=>t.side!==this.side)) if(Math.hypot(t.x-target.x,t.y-target.y)<=splashRad) t.hp-=(this.dmg*this.atkCooldown);
            // Wizard pulse centered on target
            spawnPulse(target.x, target.y, splashRad, this.color);
          }
        } else if(this.heal){
          // handled earlier in healer branch (shouldn't reach here)
        } else {
          if(this.atkTimer<=0){
            this.atkTimer=this.atkCooldown;

            // calculate base damage for this attack tick
            const baseDamage = this.dmg * this.atkCooldown;

            /* --------- SPECIAL SPIRIT BEHAVIORS --------- */
            if(this.type === 'spirit_boom'){
              // Big splash and double damage vs buildings/towers
              const splashR = 96 * globalScale; // larger radius
              // damage primary
              if(target instanceof Tower){
                target.hp -= baseDamage * 2;
              } else {
                target.hp -= baseDamage;
              }
              // splash to nearby units (reduced) and buildings (double)
              for(const u of units.filter(u=>u.side!==this.side&&u.alive)){
                const d2 = Math.hypot(u.x - target.x, u.y - target.y);
                if(d2 <= splashR){
                  u.hp -= baseDamage * 0.8;
                }
              }
              for(const t of towers.filter(t=>t.side!==this.side)){
                const d2 = Math.hypot(t.x - target.x, t.y - target.y);
                if(d2 <= splashR){
                  t.hp -= baseDamage * 2;
                }
              }
              spawnExplosion(target.x || this.x, target.y || this.y, '#ffb36b', 0.3);
              spawnHitParticles(target.x || this.x, target.y || this.y, '#ffb36b', 10);

            } else if(this.type === 'spirit_zap'){
              // Chain attack: hits initial target then chains up to N times to nearest enemies
              let chainCount = 6;
              let chainRadius = 125 * globalScale;
              let chainDmg = baseDamage;
              const hitList = [];
              // helper to apply damage to an entity (tower or unit)
              const applyTo = (ent, dmg) => {
                if(!ent) return;
                if(ent instanceof Tower) ent.hp -= dmg;
                else ent.hp -= dmg;
                spawnHitParticles(ent.x || this.x, ent.y || this.y, '#f6f8a5', 4);
              };
              // start with initial target
              let current = target;
              for(let i=0;i<chainCount && current;i++){
                applyTo(current, chainDmg);
                hitList.push(current);
                // find next candidate among units and towers (enemy side), not already hit
                let candidates = [];
                for(const u of units.filter(u=>u.side!==this.side&&u.alive)) if(!hitList.includes(u)) candidates.push(u);
                for(const t of towers.filter(t=>t.side!==this.side)) if(!hitList.includes(t)) candidates.push(t);
                // find nearest candidate within chainRadius of current
                let next = null, bestD = Infinity;
                for(const c of candidates){
                  const d2 = Math.hypot((c.x||0) - (current.x||0), (c.y||0) - (current.y||0));
                  if(d2 < bestD && d2 <= chainRadius){
                    bestD = d2; next = c;
                  }
                }
                // small visual pulse per chain hop
                spawnPulse(current.x || this.x, current.y || this.y, 24*globalScale, '#f6f8a5');
                // next hop uses reduced damage
                chainDmg *= 0.85;
                current = next;
              }

            } else if(this.type === 'spirit_ice'){
              // Slows by 30% and damages any enemy within 80px
              const aoeR = 80 * globalScale;
              const slowDuration = 1.2; // seconds
              for(const u of units.filter(u=>u.side!==this.side&&u.alive)){
                const d2 = Math.hypot(u.x - target.x, u.y - target.y);
                if(d2 <= aoeR){
                  // damage
                  u.hp -= baseDamage;
                  // apply slow (reduce speed to 70%)
                  u.slowFactor = Math.min(u.slowFactor || 1, 0.1);
                  u.slowTimer = Math.max(u.slowTimer || 0, slowDuration);
                  spawnHitParticles(u.x, u.y, '#9fe0ff', 4);
                }
              }
              for(const t of towers.filter(t=>t.side!==this.side)){
                const d2 = Math.hypot(t.x - target.x, t.y - target.y);
                if(d2 <= aoeR){
                  t.hp -= baseDamage;
                }
              }
              spawnPulse(target.x || this.x, target.y || this.y, aoeR, '#9fe0ff');

            } else if(this.type === 'spirit_fire'){
              // DoT: apply burn on hit (original spirit_fire behavior)
              const burnDuration = 5.0; // seconds
              const burnDPS = Math.max(8, baseDamage * 2); // damage per second
              if(target instanceof Tower){
                target.hp -= baseDamage;
                // towers take burn as well (apply immediate small ticks)
                target.hp -= burnDPS * 1.5;
              } else {
                target.hp -= baseDamage;
                target.burnTimer = Math.max(target.burnTimer || 0, burnDuration);
                target.burnDPS = Math.max(target.burnDPS || 0, burnDPS);
              }
              spawnHitParticles(target.x || this.x, target.y || this.y, '#ff6b3a', 6);
              spawnPulse(target.x || this.x, target.y || this.y, 28*globalScale, '#ff6b3a');

            } else if(this.type === 'furnace_spirit'){
              // bespoke furnace spirit: burn like spirit_fire AND splash like wizard
              const burnDuration = 4.0; // seconds
              const burnDPS = Math.max(8, baseDamage * (this.def?.burnMultiplier || 2.0)); // use burnMultiplier from def
              // primary hit
              if(target instanceof Tower){
                target.hp -= baseDamage;
                target.hp -= burnDPS * 1.2; // immediate ticks for towers
              } else {
                target.hp -= baseDamage;
                target.burnTimer = Math.max(target.burnTimer || 0, burnDuration);
                target.burnDPS = Math.max(target.burnDPS || 0, burnDPS);
              }
              // splash around target
              const splashR = Math.max(28*globalScale, this.range * 0.8);
              for(const u of units.filter(u=>u.side!==this.side&&u.alive)){
                const d2 = Math.hypot(u.x - target.x, u.y - target.y);
                if(d2 <= splashR){
                  if(u instanceof Tower) { u.hp -= baseDamage * 0.9; }
                  else { u.hp -= baseDamage * 0.8; u.burnTimer = Math.max(u.burnTimer||0, burnDuration*0.6); u.burnDPS = Math.max(u.burnDPS||0, burnDPS*0.7); }
                }
              }
              for(const t of towers.filter(t=>t.side!==this.side)){
                const d2 = Math.hypot(t.x - target.x, t.y - target.y);
                if(d2 <= splashR){
                  t.hp -= baseDamage * 1.1;
                }
              }
              
              spawnExplosion(target.x || this.x, target.y || this.y, '#ff8f4a', 0.4);
              spawnHitParticles(target.x || this.x, target.y || this.y, '#ff8f4a', 8);
              this._dying = true;
              this._dyingTimer = 0;
              this.alive = false;
              


            } else {
              // Default: normal single-target hit (non projectile)
              if(target instanceof Tower) target.hp -= baseDamage; else target.hp -= baseDamage;
              spawnHitParticles((target.x||this.x),(target.y||this.y), (target.color||this.color), 4);
              // Swing effect for melee units (exclude mega and Valkyrie)
              const isMelee = !isRanged(this.def);
              if(isMelee && !this.mega && this.type !== 'valkyrie'){
                const ang = Math.atan2(target.y - this.y, target.x - this.x);
                spawnSwing(this.x, this.y, this.range, ang, this.color);
              }
            }

            // end special behavior branch

            // note: projectiles handled elsewhere (not part of spirits)
          }
        }
      }
    }

    if(this.hp<=0 && !this._dying){
      // Special: if a golem dies, spawn 3 golemites
      if (this.type === 'golem') {
        for (let i = 0; i < 3; i++) {
          const offsX = (Math.random() - 0.5) * 24;
          const offsY = (Math.random() - 0.5) * 24;
          const gx = clamp(this.x + offsX, 20 * globalScale, W - 20 * globalScale);
          const gy = clamp(this.y + offsY, 20 * globalScale, H - 20 * globalScale);
          const pos = (typeof findSpawnPosition === 'function') ? findSpawnPosition(gx, gy, this.side, 6 * globalScale) : {x:gx,y:gy};
          if (pos) {
            const gm = new Unit(pos.x, pos.y, this.side, 'golemite');
            gm.spawnTimer = 0.12;
            units.push(gm);
          }
        }
        spawnExplosion(this.x, this.y, '#b86f3c', 1.2);
        spawnHitParticles(this.x, this.y, '#b86f3c', 18);
      }

      // If a golemite dies and wasn't already handled above, ensure explosion occurs (defensive)
      if (this.type === 'golemite' || this.type === 'golemite') {
        const exR = (DATA.golemite.explosionRadius || 84) * globalScale;
        const exD = DATA.golemite.explosionDamage || 420;
        for (const u of units.filter(u => u.side !== this.side && u.alive)) {
          const d2 = Math.hypot(u.x - this.x, u.y - this.y);
          if (d2 <= exR) {
            u.hp -= exD * (1 - (d2 / (exR+1)));
          }
        }
        for (const t of towers.filter(t => t.side !== this.side)) {
          const d2 = Math.hypot(t.x - this.x, t.y - this.y);
          if (d2 <= exR) {
            t.hp -= exD * (1 - (d2 / (exR+1)));
          }
        }
        for (const b of units.filter(u=>u.side!==this.side && (u.hut||u.pump||u.turret||u.furnace))) {
          const d2 = Math.hypot(b.x - this.x, b.y - this.y);
          if (d2 <= exR) {
            b.hp -= exD * (1 - (d2 / (exR+1)));
          }
        }
        spawnExplosion(this.x, this.y, '#ffb36b', 0.9);
        spawnHitParticles(this.x, this.y, '#ffb36b', 12);
      }

      this._dying = true; this._dyingTimer = 0; this.alive = false;
      for(let i=0;i<14;i++){ particles.push(new Particle(this.x + (Math.random()-0.5)*(this.size*1.6), this.y + (Math.random()-0.5)*(this.size*1.6), this.color, 4 + Math.random()*5, (Math.random()-0.5)*220, -80 + Math.random()*-40, 0.9 + Math.random()*0.6)); }
    }

    this.x=clamp(this.x,10*globalScale,W-10*globalScale); this.y=clamp(this.y,10*globalScale,H-10*globalScale);
  }
}

class SpellEffect{
  constructor(type,x,y,side){ this.type=type; this.x=x; this.y=y; this.side=side; this.created=now(); this.duration=SPELLS[type].duration||0.6; this.radius=(SPELLS[type].radius||48)*globalScale; this.damage=SPELLS[type].damage||0; this.applied=false; this.color=SPELLS[type].color||'#fff' }
  applyOnce(){
    if(this.applied) return; this.applied=true;
    for(const u of units.filter(u=>u.alive)){
      // treat hut / pump / turret / furnace as building rects
      if(u.hut || u.pump || u.turret || u.furnace){
        const rect = rectFromBuilding(u);
        if(circleIntersectsRect(this.x, this.y, this.radius + 0.5, rect) && u.side !== this.side){
          u.hp -= this.damage; spawnHitParticles(u.x,u.y,u.color, 8);
        }
      } else {
        const d = Math.hypot(u.x - this.x, u.y - this.y);
        if(u.side !== this.side && d <= this.radius + (u.size||10)){
          u.hp -= this.damage; spawnHitParticles(u.x,u.y,u.color, 6);
        }
      }
    }
    for(const t of towers){
      const rect = {left: t.x - t.size/2, right: t.x + t.size/2, top: t.y - t.size*0.8, bottom: t.y + t.size*0.8};
      if(circleIntersectsRect(this.x, this.y, this.radius + 0.5, rect) && t.side !== this.side){
        t.hp -= this.damage * TOWER_SPELL_DMG_MULT;
      }
    }
  }
  update(dt){ if(!this.applied) this.applyOnce(); }
  draw(ctx){ const elapsed=now()-this.created; const p=clamp(1-(elapsed/this.duration),0,1); ctx.save(); const r=this.radius*(1+(1-p)*0.2); ctx.fillStyle=this.color; ctx.globalAlpha=0.16*p; ctx.beginPath(); ctx.arc(this.x,this.y,r,0,Math.PI*2); ctx.fill(); ctx.globalAlpha=0.9*p; ctx.strokeStyle=this.color; ctx.lineWidth=2+(1-p)*2; ctx.beginPath(); ctx.arc(this.x,this.y,r,0,Math.PI*2); ctx.stroke(); ctx.restore() }
  isDone(){ return (now()-this.created) >= this.duration }
}

class LogProjectile{
  constructor(x,y,side){
    this.side=side;
    if(side==='player'){ this.x=clamp(x,10*globalScale,W/2-10*globalScale); this.vx=(SPELLS.log.speed||225)*globalScale; }
    else { this.x=clamp(x, W/2+10*globalScale, W-10*globalScale); this.vx=-(SPELLS.log.speed||225)*globalScale; }
    this.bodyWidth=(SPELLS.log.bodyWidth||28)*globalScale;
    this.height=Math.floor(H*(SPELLS.log.heightFrac||(1/3)));
    this.y=clamp(y,this.height/2+10*globalScale,H-this.height/2-10*globalScale);
    this.damage=SPELLS.log.damage; this.knockback=SPELLS.log.knockback*globalScale; this.color=SPELLS.log.color; this.hitSet=new Set(); this.created=now(); this.alive=true;
  }
  update(dt){
    this.x += this.vx * dt;
    const left = this.x - this.bodyWidth/2, right = left + this.bodyWidth, top = this.y - this.height/2, bottom = top + this.height;
    for(const u of units.filter(u=>u.alive && u.side !== this.side)){
      if(this.hitSet.has(u)) continue;
      // treat hut / pump / turret / furnace as rects
      if(u.hut || u.pump || u.turret || u.furnace){
        const rect = rectFromBuilding(u);
        if(rectsOverlap({left,right,top,bottom}, rect)){
          u.hp -= this.damage; this.hitSet.add(u); spawnHitParticles(u.x,u.y,u.color,5);
        }
      } else {
        const closestX = clamp(u.x, left, right);
        const closestY = clamp(u.y, top, bottom);
        const dx = u.x - closestX, dy = u.y - closestY;
        if((dx*dx + dy*dy) <= (u.size + 2)*(u.size + 2)){
          u.hp -= this.damage; const dir = (u.x >= this.x) ? 1 : -1;
          u.vx += (this.knockback*dir)*0.7; u.vy += (Math.random()-0.5)*80*globalScale;
          this.hitSet.add(u); spawnHitParticles(u.x,u.y,u.color,5);
        }
      }
    }
    for(const t of towers.filter(t=>t.side!==this.side)){
      const rect = {left: t.x - t.size/2, right: t.x + t.size/2, top: t.y - t.size*0.8, bottom: t.y + t.size*0.8};
      if(!(right < rect.left || left > rect.right || bottom < rect.top || top > rect.bottom)){
        t.hp -= this.damage * TOWER_SPELL_DMG_MULT;
      }
    }
    if(this.x - this.bodyWidth/2 > W + 50 || this.x + this.bodyWidth/2 < -50) this.alive = false;
  }
  draw(ctx){
    const left=this.x-this.bodyWidth/2, w=this.bodyWidth, h=this.height;
    ctx.save(); ctx.fillStyle=this.color; ctx.globalAlpha=0.98; ctx.fillRect(left,this.y-h/2,w,h);
    ctx.strokeStyle='rgba(0,0,0,0.25)'; ctx.lineWidth=2; ctx.strokeRect(left,this.y-h/2,w,h);
    ctx.font='bold 14px sans-serif'; ctx.textAlign='center'; ctx.textBaseline='middle'; ctx.fillStyle='rgba(0,0,0,0.7)'; ctx.fillText('LOG',this.x,this.y); ctx.restore();
  }
}

/* ---------- SPAWN & DEPLOY ---------- */
function findSpawnPosition(x,y,side,size){
  const maxRadius=80*globalScale, step=Math.max(4*globalScale,8*globalScale);
  for(let r=0;r<=maxRadius;r+=step){
    for(let a=0;a<360;a+=24){
      const rad=a*Math.PI/180; const nx=x+Math.cos(rad)*r; const ny=y+Math.sin(rad)*r;
      if(side==='player'&&nx>(W/2-6*globalScale)) continue;
      if(side==='enemy'&&nx<(W/2+6*globalScale)) continue;
      if(nx<20*globalScale||nx>W-20*globalScale||ny<20*globalScale||ny>H-20*globalScale) continue;
      let ok=true;
      for(const u of units){ 
        if(!u.alive && !u._dying) continue;
        // treat hut/pump/turret/furnace as blocking rectangles
        if(u.hut || u.pump || u.turret || u.furnace){
          const rect = rectFromBuilding(u);
          if(pointNearRect(nx,ny,rect, size + 6)) { ok=false; break }
        } else {
          const d=Math.hypot(u.x-nx,u.y-ny); if(d<(u.size+size+4)){ ok=false; break }
        }
      }
      if(!ok) continue;
      for(const t of towers){ const rect = {left: t.x - t.size/2, right: t.x + t.size/2, top: t.y - t.size*0.8, bottom: t.y + t.size*0.8}; if(pointNearRect(nx,ny,rect,size+8)){ ok=false; break } }
      if(ok) return {x:nx,y:ny};
    }
  }
  return null;
}
function countStructures(side, type){ return units.filter(u => (u.type===type) && (u.side===side) && (u.alive || u._dying)).length; }

function canUse(side,key){ const last=lastUsedCard[side+'_'+key]||0; return (now()-last)>=CONFIG.cardCooldown; }
function useCard(side,key){ lastUsedCard[side+'_'+key]=now(); }
function canUseSpell(side,sk){ const last=lastUsedSpell[side+'_spell_'+sk]||0; return (now()-last)>=CONFIG.cardCooldown; }
function useSpell(side,sk){ lastUsedSpell[side+'_spell_'+sk]=now(); }

function tryDeploy(x,y,side,cardKey){
  if(x<0||x>W||y<0||y>H) return false;
  if(side==='player'&&x>W/2) return false;
  const def=DATA[cardKey];
  if(cardKey==='goblins'){ if(side==='player'&&elixirP<DATA.goblins.cost) return false; if(side==='enemy'&&elixirE<DATA.goblins.cost) return false }
  else { if(side==='player'&&def&&elixirP<(def.cost||0)) return false; if(side==='enemy'&&def&&elixirE<(def.cost||0)) return false }
  if(!canUse(side,cardKey)) return false;
  if(cardKey==='elixirPump'){ if(countStructures(side,'elixirPump') >= 5) return false; }
  if(cardKey==='goblinHut'){ if(countStructures(side,'goblinHut') >= 3) return false; }
  if(cardKey==='crossbow'){ if(countStructures(side,'crossbow') >= 5) return false; }
  const size=(def&&def.size?def.size:10)*ART_SCALE*globalScale;
  const pos=findSpawnPosition(x,y,side,size); if(!pos) return false;
  if(cardKey==='goblins'){
    if(side==='player') elixirP=clamp(elixirP-DATA.goblins.cost,0,CONFIG.maxElixir); else elixirE=clamp(elixirE-DATA.goblins.cost,0,CONFIG.maxElixir);
    useCard(side,cardKey);
    const offs=[[-18,-12],[18,-12],[-18,12],[18,12]];
    for(let i=0;i<4;i++){ const ox=offs[i][0]+(Math.random()-0.5)*6; const oy=offs[i][1]+(Math.random()-0.5)*6; units.push(new Unit(clamp(pos.x+ox*globalScale,20*globalScale,W-20*globalScale),clamp(pos.y+oy*globalScale,20*globalScale,H-20*globalScale),side,'goblin')) }
    return true;
  } else {
    if(side==='player') elixirP=clamp(elixirP-(def.cost||0),0,CONFIG.maxElixir); else elixirE=clamp(elixirE-(def.cost||0),0,CONFIG.maxElixir);
    useCard(side,cardKey);
    const px=clamp(pos.x,40*globalScale,W-40*globalScale), py=clamp(pos.y,40*globalScale,H-40*globalScale);
    if(cardKey==='goblinHut'){ const hut=new Unit(px,py,side,'goblinHut'); hut.pumpLike=true; units.push(hut) }
    else if(cardKey==='elixirPump'){ units.push(new Unit(px,py,side,'elixirPump')) }
    else {
      // Use the centralized spawn helper so cards that spawn multiple units (archer spawnCount:2) or bands (spiritBand) work.
      // spawnCardUnits will push new Unit instances into `units`.
      if(typeof spawnCardUnits === 'function'){
        spawnCardUnits(px, py, side, cardKey);
        // If this card is a mega unit (single spawn), set its megaHome like previous behavior.
        if(def && def.mega){
          for(let i=units.length-1;i>=0;i--){
            const u = units[i];
            if(u.side===side && u.type===cardKey){
              u.megaHome = { x: px, y: py };
              break;
            }
          }
        }
      } else {
        // Fallback: create single unit (legacy behavior)
        const u=new Unit(px,py,side,cardKey); if(u.mega) u.megaHome={x:px,y:py}; units.push(u);
      }
    }
    return true;
  }
}
function tryDeploySpell(x,y,spellKey,side){
  const s=SPELLS[spellKey]; if(!s) return false;
  if(side==='player' && elixirP<s.cost) return false;
  if(side==='enemy' && elixirE<s.cost) return false;
  if(!canUseSpell(side,spellKey)) return false;
  if(spellKey==='log'){
    if(side==='player' && x>W/2) return false;
    if(side==='enemy' && x < W/2) return false;
    const log=new LogProjectile(x,clamp(y,40*globalScale,H-40*globalScale),side); spellsActive.push(log);
  } else {
    const se=new SpellEffect(spellKey,x,y,side); spellsActive.push(se);
  }
  if(side==='player') elixirP=clamp(elixirP-s.cost,0,CONFIG.maxElixir); else elixirE=clamp(elixirE-s.cost,0,CONFIG.maxElixir);
  useSpell(side,spellKey);
  return true;
}

/* ---------- AI spawn (rare spells allowed) ---------- */
function spawnEnemyAI(){
  // include new units in AI spawn choices (furnace included if top half added it)
  const choices=['knight','archer','giant','wizard','healer','goblins','elixirPump','valkyrie','minipekka','megaknight','goblinHut','crossbow','spiritBand','golem','replicator','furnace'];
  const key=choices[Math.floor(Math.random()*choices.length)]; const def=DATA[key]||DATA['goblin'];
  const spawnPadScaled=CONFIG.spawnPad*globalScale;
  if(Math.random() < 0.06){
    const spells = Object.keys(SPELLS).filter(sk => elixirE >= SPELLS[sk].cost && canUseSpell('enemy', sk));
    if(spells.length){
      const sk = spells[Math.floor(Math.random()*spells.length)];
      const y0 = Math.random()*(H-160*globalScale)+80*globalScale;
      const x0 = W - spawnPadScaled - 40*globalScale;
      tryDeploySpell(x0, y0, sk, 'enemy');
      return;
    }
  }
  if(key==='goblins'){ if(elixirE>=DATA.goblins.cost && canUse('enemy','goblins')){ const y0=Math.random()*(H-160*globalScale)+80*globalScale; const x0=W-spawnPadScaled-40*globalScale; tryDeploy(x0,y0,'enemy','goblins') } }
  else if(def&&elixirE>=def.cost && canUse('enemy',key)){
    const y0=Math.random()*(H-160*globalScale)+80*globalScale; const x0=W-spawnPadScaled-20*globalScale; tryDeploy(x0,y0,'enemy',key)
  }
}


// replace the setInterval with:
setInterval(() => { if (running) spawnEnemyAI(); }, ENEMY_SPAWN_BASE + Math.random() * ENEMY_SPAWN_JITTER);


/* elixir regen */
setInterval(()=>{ if(!running) return; elixirP=clamp(elixirP+CONFIG.elixirGainPerSec*0.1,0,CONFIG.maxElixir); elixirE=clamp(elixirE+CONFIG.elixirGainPerSec*0.1,0,CONFIG.maxElixir) },100);

/* ---------- COLLISIONS ---------- */
function resolveCollisions(){
  for(let i=0;i<units.length;i++){ const a=units[i]; if(!a.alive) continue; for(let j=i+1;j<units.length;j++){ const b=units[j]; if(!b.alive) continue; const dx=a.x-b.x,dy=a.y-b.y,d=Math.hypot(dx,dy),minDist=a.size+b.size+1; if(d>0&&d<minDist){ const overlap=minDist-d,nx=dx/d,ny=dy/d; if(b.immobile&&!a.immobile){ a.x+=nx*overlap; a.y+=ny*overlap } else if(a.immobile&&!b.immobile){ b.x-=nx*overlap; b.y-=ny*overlap } else { a.x+=nx*(overlap*0.5); a.y+=ny*(overlap*0.5); b.x-=nx*(overlap*0.5); b.y-=ny*(overlap*0.5) } const push=0.2; a.vx+=nx*push*overlap; a.vy+=ny*push*overlap; b.vx-=nx*push*overlap; b.vy-=ny*push*overlap } } }
  for(const u of units){ if(!u.alive) continue; for(const t of towers){ const dx=u.x-t.x,dy=u.y-t.y,d=Math.hypot(dx,dy),minDist=u.size+(t.size||20)+4; if(d<minDist&&d>0){ const overlap=minDist-d,nx=dx/d,ny=dy/d; u.x+=nx*overlap; u.y+=ny*overlap; u.vx+=nx*0.2*overlap; u.vy+=ny*0.2*overlap; } } }
}

/* ---------- MAIN LOOP ---------- */
let last = performance.now();
function frame(nowTs){
  requestAnimationFrame(frame);
  let dt=(nowTs-last)/1000; last=nowTs; if(dt<=0) return; if(dt>CONFIG.dtCap) dt=CONFIG.dtCap;

  if(running){
    for(const t of towers) t.update(dt,units);
    for(const u of units) u.update(dt,units,towers);
    for(const s of spellsActive){ if(s instanceof LogProjectile) s.update(dt); else s.update(dt) }
    spellsActive=spellsActive.filter(s=>(s instanceof LogProjectile)?s.alive:!s.isDone());
    for(const p of projectiles) p.update(dt);
    projectiles = projectiles.filter(p=>p.alive);

    // update pulses and swings
    for(const p of pulses) p.update(dt);
    pulses = pulses.filter(p=>!p.isDone());
    for(const s of swings) s.update(dt);
    swings = swings.filter(s=>!s.isDone());

    resolveCollisions();
    for(const p of particles) p.update(dt);
    particles = particles.filter(p=>!p.isDone());
    for(const ex of explosions) ex.age = (ex.age || 0) + dt;
    explosions = explosions.filter(ex => { ex.r = (ex.r || 0) + (ex.maxR * (dt/ex.life || 0)); return ex.age < ex.life; });

    units = units.filter(u => {
      if(u._dying){
        if(u._dyingTimer > u.deathDuration) return false;
        return true;
      }
      return u.alive;
    });

    for(let i=towers.length-1;i>=0;i--){
      if(towers[i].hp<=0) towers.splice(i,1);
    }

    const pT=towers.filter(t=>t.side==='player'), eT=towers.filter(t=>t.side==='enemy');
    if(pT.length===0||eT.length===0) running=false;
  }

  updateCardButtonStates(); updateSpellButtonStates();

  render();
}
requestAnimationFrame(frame);

/* ---------- RENDER (with screen shake) ---------- */
function render(){
  let sx = 0, sy = 0;
  if(shakeTime > 0){
    const t = Math.min(1, shakeTime);
    sx = (Math.random()*2-1) * shakeIntensity;
    sy = (Math.random()*2-1) * shakeIntensity;
    shakeTime = Math.max(0, shakeTime - 1/60);
    shakeIntensity = Math.max(0, shakeIntensity * 0.96);
  }

  ctx.save();
  ctx.translate(Math.round(sx), Math.round(sy));

  ctx.fillStyle='#0e0f11'; ctx.fillRect(0,0,W,H);

  ctx.save(); ctx.strokeStyle='rgba(255,255,255,0.04)'; ctx.lineWidth=2; ctx.setLineDash([6,6]); ctx.beginPath(); ctx.moveTo(W/2,0); ctx.lineTo(W/2,H); ctx.stroke(); ctx.setLineDash([]); ctx.font='12px sans-serif'; ctx.fillStyle='rgba(255,255,255,0.04)'; ctx.textAlign='center'; ctx.fillText('— no-deploy zone —',W/2,18); ctx.restore();

  for(let i=1;i<=3;i++){ const y=(H/4)*i; ctx.fillStyle='rgba(255,255,255,0.01)'; ctx.fillRect(0,y-1,W,1) }

  // draw towers & units & spells first
  for(const t of towers) t.draw(ctx);
  for(const u of units) u.draw(ctx);
  for(const s of spellsActive) s.draw(ctx);

  // pulses and swings must render over unit/building sprites
  for(const p of pulses) p.draw(ctx);
  for(const s of swings) s.draw(ctx);

  // projectiles, particles, explosions afterwards
  for(const p of projectiles) p.draw(ctx);
  for(const p of particles) p.draw(ctx);

  for(const ex of explosions){
    const progress = clamp(ex.age / ex.life, 0, 1);
    ctx.save();
    ctx.globalAlpha = (1 - progress) * 0.9;
    ctx.strokeStyle = ex.color || '#ffd54f';
    ctx.lineWidth = 6 * (1 - progress);
    ctx.beginPath();
    ctx.arc(ex.x, ex.y, ex.maxR * progress, 0, Math.PI*2);
    ctx.stroke();
    ctx.restore();
  }

  ctx.restore();

  document.getElementById('elixirTextP').textContent=`P: ${elixirP.toFixed(1)}`;
  document.getElementById('elixirTextE').textContent=`E: ${elixirE.toFixed(1)}`;
  document.getElementById('elixirFillP').style.width=clamp(elixirP/CONFIG.maxElixir*100,0,100)+'%';
  document.getElementById('elixirFillE').style.width=clamp(elixirE/CONFIG.maxElixir*100,0,100)+'%';

  const topRight=document.getElementById('topRight');
  if(!running){ if(towers.filter(t=>t.side==='enemy').length===0) topRight.textContent='You Win!'; else if(towers.filter(t=>t.side==='player').length===0) topRight.textContent='You Lose!'; else topRight.textContent='Paused' } else topRight.textContent='';
}

/* ---------- RESET ---------- */
function resetGame(){
  units=[]; spellsActive=[]; particles=[]; explosions=[]; projectiles=[]; pulses=[]; swings=[];
  towers=[
    new Tower(80*globalScale,H*0.25||60*globalScale,'player'),
    new Tower(80*globalScale,H*0.5||Math.max(60*globalScale,H/2),'player'),
    new Tower(80*globalScale,H*0.75||Math.max(120*globalScale,H*0.75),'player'),
    new Tower(W-80*globalScale,H*0.25||60*globalScale,'enemy'),
    new Tower(W-80*globalScale,H*0.5||Math.max(60*globalScale,H/2),'enemy'),
    new Tower(W-80*globalScale,H*0.75||Math.max(120*globalScale,H*0.75),'enemy')
  ];
  elixirP=5; elixirE=5; running=true; selectedCard='knight'; selectedSpell=null;
  for(const k in lastUsedCard) delete lastUsedCard[k];
  for(const k in lastUsedSpell) delete lastUsedSpell[k];
}

/* ---------- UI BUILDERS (card + spell buttons) ---------- */
/* added: golem and replicator to cardOrder so they'll appear in the UI (also furnace added) */
const cardOrder={knight:'Knight',archer:'Archer',spiritBand:'Spirit Band',giant:'Giant',wizard:'Wizard',healer:'Healer',valkyrie:'Valkyrie',goblins:'Goblins',goblinHut:'Goblin Hut',minipekka:'Mini P.E.K.K.A',megaknight:'Mega Knight',elixirPump:'Elixir Pump',crossbow:'Crossbow',furnace:'Furnace',golem:'Golem',replicator:'Replicator'};
const cardButtonElements={}, spellButtonElements={};
function sortedCardKeys(){return Object.keys(cardOrder).sort((a,b)=>{const ca=(DATA[a]&&DATA[a].cost)?DATA[a].cost:(a==='goblins'?DATA.goblins.cost:0);const cb=(DATA[b]&&DATA[b].cost)?DATA[b].cost:(b==='goblins'?DATA.goblins.cost:0);if(ca!==cb)return ca-cb;return cardOrder[a].localeCompare(cardOrder[b])})}

function buildCardButtons(){ if(!cardButtons) return; cardButtons.innerHTML=''; for(const key of sortedCardKeys()){ const def=DATA[key]||{cost:0}; const cost=def.cost??(key==='goblins'?DATA.goblins.cost:0); const color=def.color||'#777'; const btn=document.createElement('button'); btn.className='btn'; btn.dataset.card=key; btn.dataset.color=color; const left=document.createElement('div'); left.className='cardLabel'; const icon=document.createElement('span'); icon.className='cardIcon'; icon.style.background=color; const name=document.createElement('span'); name.className='cardName'; name.textContent=`${cardOrder[key]}`; left.appendChild(icon); left.appendChild(name); const right=document.createElement('div'); right.style.display='flex'; right.style.alignItems='center'; const costSpan=document.createElement('span'); costSpan.className='cost'; costSpan.textContent=`(${cost})`; right.appendChild(costSpan); btn.appendChild(left); btn.appendChild(right); 
    const overlay=document.createElement('div'); overlay.className='coolOverlay'; const fill=document.createElement('div'); fill.className='coolFill'; const text=document.createElement('div'); text.className='coolText'; text.textContent=''; overlay.appendChild(fill); overlay.appendChild(text); btn.appendChild(overlay);
    btn.addEventListener('click',(e)=>{ if(btn.classList.contains('disabled')) return; selectedCard=key; selectedSpell=null; updateCardButtonStates(); updateSpellButtonStates(); }); cardButtons.appendChild(btn); cardButtonElements[key]=btn; } }

function buildSpellButtons(){ if(!spellButtons) return; spellButtons.innerHTML=''; for(const sk of ['fireball','arrows','log']){ const s=SPELLS[sk]; const btn=document.createElement('button'); btn.className='btn spellCompact'; btn.dataset.spell=sk; btn.dataset.color=s.color; const left=document.createElement('div'); left.className='cardLabel'; const name=document.createElement('span'); name.className='cardName'; name.textContent=`${s.name}`; left.appendChild(name); const right=document.createElement('div'); right.style.display='flex'; right.style.alignItems='center'; const costSpan=document.createElement('span'); costSpan.className='cost'; costSpan.textContent=`(${s.cost})`; right.appendChild(costSpan); btn.appendChild(left); btn.appendChild(right);
    const overlay=document.createElement('div'); overlay.className='coolOverlay'; const fill=document.createElement('div'); fill.className='coolFill'; const text=document.createElement('div'); text.className='coolText'; text.textContent=''; overlay.appendChild(fill); overlay.appendChild(text); btn.appendChild(overlay);
    btn.addEventListener('click',(e)=>{ if(btn.classList.contains('disabled')) return; selectedSpell=sk; selectedCard=null; updateSpellButtonStates(); updateCardButtonStates(); }); spellButtons.appendChild(btn); spellButtonElements[sk]=btn; } }

function updateCardButtonStates(){ for(const key of Object.keys(cardButtonElements)){ const btn=cardButtonElements[key]; if(!btn) continue; const def=DATA[key]||{cost:0}; const cost=def.cost??(key==='goblins'?DATA.goblins.cost:0); if(elixirP<cost) btn.classList.add('disabled'); else btn.classList.remove('disabled'); if(selectedCard===key) btn.classList.add('selected'); else btn.classList.remove('selected'); const color=btn.dataset.color||'#777'; if(btn.classList.contains('disabled')) btn.style.border=`2px solid rgba(150,150,150,0.12)`; else btn.style.border=`2px solid ${color}`; const ic=btn.querySelector('.cardIcon'); if(ic) ic.style.filter=btn.classList.contains('disabled')?'grayscale(.6) brightness(.9)':''; const costSpan=btn.querySelector('.cost'); if(costSpan){ costSpan.textContent=`(${cost})`; costSpan.style.color='var(--elixir)'; } 
    const overlay = btn.querySelector('.coolOverlay'); const fill = overlay && overlay.querySelector('.coolFill'); const text = overlay && overlay.querySelector('.coolText'); const last = lastUsedCard['player_'+key]||0; const rem = Math.max(0, CONFIG.cardCooldown - (now()-last)); const frac = Math.min(1, rem/CONFIG.cardCooldown); if(frac>0){ overlay.style.opacity='1'; if(fill) fill.style.height=(frac*100)+'%'; if(text) text.textContent = Math.ceil(rem*10)/10 + 's'; } else { overlay.style.opacity='0'; if(fill) fill.style.height='0%'; if(text) text.textContent=''; } } }

function updateSpellButtonStates(){ for(const k of Object.keys(spellButtonElements)){ const btn=spellButtonElements[k]; if(!btn) continue; const def=SPELLS[k]; const cost=def.cost; if(elixirP<cost) btn.classList.add('disabled'); else btn.classList.remove('disabled'); if(selectedSpell===k) btn.classList.add('selected'); else btn.classList.remove('selected'); const color=btn.dataset.color||'#777'; if(btn.classList.contains('disabled')) btn.style.border=`2px solid rgba(150,150,150,0.12)`; else btn.style.border=`2px solid ${color}`; const costSpan=btn.querySelector('.cost'); if(costSpan){ costSpan.textContent=`(${cost})`; costSpan.style.color='var(--elixir)'; } 
    const overlay = btn.querySelector('.coolOverlay'); const fill = overlay && overlay.querySelector('.coolFill'); const text = overlay && overlay.querySelector('.coolText'); const last = lastUsedSpell['player_spell_'+k]||0; const rem = Math.max(0, CONFIG.cardCooldown - (now()-last)); const frac = Math.min(1, rem/CONFIG.cardCooldown); if(frac>0){ overlay.style.opacity='1'; if(fill) fill.style.height=(frac*100)+'%'; if(text) text.textContent = Math.ceil(rem*10)/10 + 's'; } else { overlay.style.opacity='0'; if(fill) fill.style.height='0%'; if(text) text.textContent=''; } } }

/* ---------- INPUT HANDLING (deploy + delete) ---------- */
canvas.addEventListener('pointerdown',(ev)=>{ if(!running) return; const rect = canvas.getBoundingClientRect(); const x = ev.clientX - rect.left; const y = ev.clientY - rect.top;
  if(deleteMode){
    const clicked = findPlayerEntityAt(x,y);
    if(clicked){
      const idx = units.indexOf(clicked);
      if(idx!==-1){ spawnExplosion(clicked.x, clicked.y, clicked.color, 0.9); units.splice(idx,1); }
    }
    exitDeleteMode();
    updateCardButtonStates(); updateSpellButtonStates();
    return;
  }

  if(selectedSpell){
    if(tryDeploySpell(x,y,selectedSpell,'player')){ updateSpellButtonStates(); updateCardButtonStates(); }
    return;
  }
  if(x>=0&&x<=canvas.width&&y>=0&&y<=canvas.height){
    if(x<=canvas.width/2){
      if(tryDeploy(x,y,'player',selectedCard)) updateCardButtonStates();
    }
  }
});

/* Delete button handling */
const deleteBtn = document.getElementById('deleteBtn');
deleteBtn.addEventListener('click', ()=>{
  deleteMode = !deleteMode;
  if(deleteMode) enterDeleteMode(); else exitDeleteMode();
});
function enterDeleteMode(){
  deleteMode = true;
  deleteBtn.classList.add('deleteActive');
  canvas.classList.add('canvas-delete-cursor');
}
function exitDeleteMode(){
  deleteMode = false;
  deleteBtn.classList.remove('deleteActive');
  canvas.classList.remove('canvas-delete-cursor');
}
function findPlayerEntityAt(x,y){
  for(let i=units.length-1;i>=0;i--){
    const u = units[i];
    if(u.side!=='player') continue;
    if(u.hut || u.pump || u.turret || u.furnace){
      const r = rectFromBuilding(u);
      if(x>=r.left && x<=r.right && y>=r.top && y<=r.bottom) return u;
    } else {
      const d = Math.hypot(u.x - x, u.y - y);
      if(d <= (u.size||8)) return u;
    }
  }
  return null;
}

/* Pause & reset */
document.getElementById('pauseBtn').addEventListener('click',()=>{ running = !running; updatePauseButton() });
document.getElementById('resetBtn').addEventListener('click',()=>{ resetGame(); updatePauseButton(); updateCardButtonStates(); updateSpellButtonStates() });
function updatePauseButton(){ const p=document.getElementById('pauseBtn'); p.textContent=running?'Pause':'Resume' }

/* ---------- RESIZE ---------- */
function rescaleAll(factor){
  for(const u of units){
    u.x *= factor; u.y *= factor;
    u.vx *= factor; u.vy *= factor;
    u.desiredVx *= factor; u.desiredVy *= factor;
    if(u._dashOrigin){ u._dashOrigin.x *= factor; u._dashOrigin.y *= factor; }
    if(u._dashTarget && typeof u._dashTarget.x === 'number'){ u._dashTarget.x *= factor; u._dashTarget.y *= factor; }
    u.size *= factor;
    u.spd *= factor;
    u.range *= factor;
    if(u.hut) u.hutDetectionRadius = (u.hutDetectionRadius || DATA.goblinHut.detectionRadius * prevScale) * factor;
    // furnace detection radius (if furnace exists in DATA)
    if(u.furnace){
      const base = (DATA.furnace && DATA.furnace.spawnDetectionRadius) ? DATA.furnace.spawnDetectionRadius : (DATA.goblinHut && DATA.goblinHut.detectionRadius) || 160;
      u.furnaceDetectionRadius = (u.furnaceDetectionRadius || base * prevScale) * factor;
    }
  }
  for(const t of towers){
    t.x *= factor; t.y *= factor;
    t.size *= factor;
    t.range *= factor;
  }
  for(const s of spellsActive){
    if(s instanceof LogProjectile){
      s.x *= factor;
      s.vx *= factor;
      s.bodyWidth *= factor;
      s.height *= factor;
    } else {
      s.x *= factor; s.y *= factor;
      s.radius *= factor;
    }
  }
  for(const p of particles){ p.x *= factor; p.y *= factor; p.vx *= factor; p.vy *= factor; p.size *= factor; }
  for(const ex of explosions){ ex.x *= factor; ex.y *= factor; ex.maxR *= factor; }
  for(const pr of projectiles){ pr.x *= factor; pr.y *= factor; pr.speed *= factor; pr.radius *= factor; }
  for(const pu of pulses){ pu.x *= factor; pu.y *= factor; pu.r *= factor; }
  for(const sw of swings){ sw.x *= factor; sw.y *= factor; sw.r *= factor; }
}

function resize(){
  topBar.style.left = '8px'; topBar.style.right = '8px'; topBar.style.width = 'auto';
  bottomUI.style.left = '8px'; bottomUI.style.right = '8px'; bottomUI.style.width = 'auto';

  const topRect = topBar.getBoundingClientRect(), bottomRect = bottomUI.getBoundingClientRect();
  const topH = Math.ceil(topRect.height) + 8, bottomH = Math.ceil(bottomRect.height) + 8;

  const availableWidth = Math.max(120, window.innerWidth - 16);
  const availableHeight = Math.max(120, window.innerHeight - topH - bottomH);

  let fw = Math.min(availableWidth, Math.round(availableHeight * (14/9)));
  let fh = Math.round(fw * (9/14));
  if(fh > availableHeight){ fh = availableHeight; fw = Math.round(fh * (14/9)); }

  const left = Math.round((window.innerWidth - fw) / 2);
  canvas.style.width = fw + 'px'; canvas.style.height = fh + 'px'; canvas.width = fw; canvas.height = fh; canvas.style.left = left + 'px'; canvas.style.top = topH + 'px';

  const oldW = W, oldH = H;
  W = canvas.width; H = canvas.height;

  const newScale = W / BASE_W;
  if(!isFinite(newScale) || newScale <= 0) return;
  const factor = newScale / globalScale;
  if(Math.abs(factor - 1) > 1e-6) rescaleAll(factor);
  prevScale = globalScale; globalScale = newScale;
}
window.addEventListener('resize', resize);

/* ---------- STARTUP ---------- */
function buildUIAndStart(){
  resize();
  resetGame();
  buildCardButtons();
  buildSpellButtons();
  updateCardButtonStates();
  updateSpellButtonStates();
  updatePauseButton();
  setTimeout(()=>{ resize(); buildCardButtons(); buildSpellButtons(); updateCardButtonStates(); updateSpellButtonStates(); },120);
}
document.addEventListener('DOMContentLoaded', buildUIAndStart);
