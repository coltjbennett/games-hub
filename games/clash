/* ---------- PROJECTILE CLASS (arrows) ---------- */
class ArrowProjectile{
  constructor(x,y,target,damage,side,source){
    this.x = x; this.y = y; this.target = target; this.damage = damage; this.side = side; this.source = source; // source can be Unit or Tower
    this.speed = 700 * globalScale;
    this.alive = true;
    this.radius = 6 * globalScale;
    this.color = '#d8d8d8';
    this.created = now();
  }
  update(dt){
    if(!this.alive) return;
    let tx = this.target && (typeof this.target.x === 'number') ? this.target.x : null;
    let ty = this.target && (typeof this.target.y === 'number') ? this.target.y : null;
    if(tx===null || ty===null){
      this.alive = false;
      return;
    }
    const dx = tx - this.x, dy = ty - this.y;
    const d = Math.hypot(dx,dy);
    if(d < Math.max(6*globalScale, this.speed*dt)){
      this.onHit(this.target);
      this.alive = false;
      return;
    }
    const nx = dx / d, ny = dy / d;
    this.x += nx * this.speed * dt;
    this.y += ny * this.speed * dt;
    if(now()-this.created > 6) this.alive = false;
  }
  onHit(target){
    if(!target) return;
    if(target instanceof Tower){
      target.hp -= this.damage;
    } else {
      // do not apply knockback to turret/buildings (turret flag), only to normal units
      target.hp -= this.damage;
      const kb = (this.source && this.source.knockback) ? this.source.knockback : 0;
      if(kb && !target.hut && !target.pump && !target.turret && target.type!=='healer'){
        const dirX = (target.x - this.x);
        const dirY = (target.y - this.y);
        const l = Math.hypot(dirX,dirY) || 1;
        target.vx += (dirX / l) * (kb * 0.7);
        target.vy += (dirY / l) * (kb * 0.5);
      }
    }
    spawnHitParticles(target.x || this.x, target.y || this.y, target.color || '#fff', 6);
  }
  draw(ctx){
    ctx.save();
    ctx.translate(this.x, this.y);
    let ang = 0;
    if(this.target && typeof this.target.x === 'number'){
      ang = Math.atan2(this.target.y - this.y, this.target.x - this.x);
    }
    ctx.rotate(ang);
    ctx.fillStyle = this.color;
    ctx.fillRect(-10*globalScale, -1*globalScale, 18*globalScale, 2*globalScale);
    ctx.beginPath();
    ctx.moveTo(8*globalScale, 0);
    ctx.lineTo(12*globalScale, -4*globalScale);
    ctx.lineTo(12*globalScale, 4*globalScale);
    ctx.closePath();
    ctx.fill();
    ctx.restore();
  }
}

/* ---------- CLASSES (Towers, Units, Spells) ---------- */
class Tower{
  constructor(x,y,side){
    this.x=x; this.y=y; this.side=side;
    this.hp=CONFIG.towerBaseHP*UNIT_HP_MULT; this.maxHp=this.hp;
    this.range=130*ART_SCALE*globalScale; this.attackCooldown=1; this.attackTimer=0; this.dmg=160; this.size=30*ART_SCALE*globalScale;
    this._destroyed=false;
    // NOTE: towers are persistent; lifetime expiry is NOT applied to towers anymore per request.
  }
  draw(ctx){
    const w=this.size,h=this.size*1.6;
    const g = ctx.createLinearGradient(this.x-w/2, this.y-h/2, this.x+w/2, this.y+h/2);
    g.addColorStop(0, this.side==='player' ? '#1f6fb3' : '#b33f3f'); g.addColorStop(1, this.side==='player' ? '#145a8f' : '#8a2b2b');
    ctx.fillStyle=g; ctx.fillRect(this.x-w/2,this.y-h/2,w,h);
    ctx.lineWidth=2;ctx.strokeStyle=(this.side==='player')?'rgba(80,160,255,0.95)':'rgba(255,90,90,0.95)';ctx.strokeRect(this.x-w/2,this.y-h/2,w,h);
    drawLabel(ctx,'tower',this.x,this.y,Math.max(10,Math.round(this.size/2)));
    drawBar(ctx,this.x-this.size,this.y-this.size-12,this.size*2,6,clamp(this.hp/this.maxHp,0,1));
  }
  update(dt,units){
    if(this.hp<=0 && !this._destroyed){
      this._destroyed=true;
      spawnExplosion(this.x,this.y,'#ffb36b', 2.2);
    }
    if(this.hp<=0) return;
    this.attackTimer-=dt; if(this.attackTimer>0) return;
    const cand=units.filter(u=>u.side!==this.side&&u.alive&&Math.abs(u.y-this.y)<(120*globalScale));
    if(!cand.length) return; cand.sort((a,b)=>Math.hypot(a.x-this.x,a.y-this.y)-Math.hypot(b.x-this.x,b.y-this.y));
    const t=cand[0],d=Math.hypot(t.x-this.x,t.y<this.y);
    if(d<=this.range+(t.size||0)){
      this.attackTimer=this.attackCooldown;
      const damage = this.dmg * this.attackCooldown;
      const proj = new ArrowProjectile(this.x, this.y, t, damage, this.side, this);
      projectiles.push(proj);
      spawnHitParticles(this.x + (Math.random()-0.5)*6, this.y + (Math.random()-0.5)*6, '#d8d8d8', 2);
    }
  }
}

